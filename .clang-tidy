# nexenne clang-tidy configuration for the library (strict).
#
# This is the strict, "super-contained" configuration that governs the library
# headers (modules/*/include). Every relevant check family is on. Examples and
# tests carry their own relaxed .clang-tidy that inherits this file and drops the
# opinionated/style checks (clang-format and STYLE_GUIDE.org own style there).
#
# Because clang-tidy applies the translation unit's config to every header it
# pulls in, the library is linted on its own (each header as its own TU) so it
# always gets THIS config, regardless of which test or example includes it.
#
# Minimum clang-tidy version: 19 (older clang cannot compile std::expected with
# libstdc++, which the codebase uses pervasively).

Checks: >
  -*,
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  concurrency-*,
  cppcoreguidelines-*,
  hicpp-*,
  misc-*,
  modernize-*,
  performance-*,
  portability-*,
  readability-*,
  -bugprone-easily-swappable-parameters,
  -cert-dcl58-cpp,
  -cert-err58-cpp,
  -cppcoreguidelines-avoid-magic-numbers,
  -cppcoreguidelines-avoid-non-const-global-variables,
  -cppcoreguidelines-non-private-member-variables-in-classes,
  -cppcoreguidelines-pro-bounds-array-to-pointer-decay,
  -cppcoreguidelines-pro-bounds-constant-array-index,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -hicpp-no-array-decay,
  -hicpp-signed-bitwise,
  -hicpp-vararg,
  -misc-include-cleaner,
  -misc-non-private-member-variables-in-classes,
  -misc-redundant-expression,
  -modernize-use-nodiscard,
  -readability-identifier-length,
  -readability-magic-numbers

# Compile diagnostics are hard errors; the checks above run as advisory warnings.
# cert-dcl58-cpp is off because specialising std::hash for our own types is
# standard-allowed; misc-redundant-expression is off because it flags the
# intentional NaN self-compare (value != value).
WarningsAsErrors:    'clang-diagnostic-*'
HeaderFilterRegex:   '.*/nexenne/.*\.hpp$'
FormatStyle:         file
SystemHeaders:       false
UseColor:            true

CheckOptions:
  # Naming: snake_case for identifiers, PascalCase for template parameters.
  - key:   readability-identifier-naming.NamespaceCase
    value: lower_case
  - key:   readability-identifier-naming.InlineNamespaceCase
    value: lower_case
  - key:   readability-identifier-naming.ClassCase
    value: lower_case
  - key:   readability-identifier-naming.StructCase
    value: lower_case
  - key:   readability-identifier-naming.UnionCase
    value: lower_case
  - key:   readability-identifier-naming.EnumCase
    value: lower_case
  - key:   readability-identifier-naming.ScopedEnumConstantCase
    value: lower_case
  - key:   readability-identifier-naming.EnumConstantCase
    value: lower_case
  - key:   readability-identifier-naming.TypeAliasCase
    value: lower_case
  - key:   readability-identifier-naming.TypedefCase
    value: lower_case
  - key:   readability-identifier-naming.FunctionCase
    value: lower_case
  - key:   readability-identifier-naming.MethodCase
    value: lower_case
  - key:   readability-identifier-naming.VirtualMethodCase
    value: lower_case
  - key:   readability-identifier-naming.MemberCase
    value: lower_case
  - key:   readability-identifier-naming.PrivateMemberPrefix
    value: m_
  - key:   readability-identifier-naming.ProtectedMemberPrefix
    value: m_
  - key:   readability-identifier-naming.PublicMemberCase
    value: lower_case
  - key:   readability-identifier-naming.VariableCase
    value: lower_case
  - key:   readability-identifier-naming.LocalVariableCase
    value: lower_case
  - key:   readability-identifier-naming.ParameterCase
    value: lower_case
  - key:   readability-identifier-naming.ParameterPackCase
    value: lower_case
  - key:   readability-identifier-naming.GlobalVariableCase
    value: lower_case
  - key:   readability-identifier-naming.GlobalConstantCase
    value: lower_case
  - key:   readability-identifier-naming.StaticConstantCase
    value: lower_case
  - key:   readability-identifier-naming.ConstantCase
    value: lower_case
  - key:   readability-identifier-naming.ConstexprVariableCase
    value: lower_case
  - key:   readability-identifier-naming.ConstexprFunctionCase
    value: lower_case
  - key:   readability-identifier-naming.ConstexprMethodCase
    value: lower_case
  - key:   readability-identifier-naming.MacroDefinitionCase
    value: UPPER_CASE
  - key:   readability-identifier-naming.TemplateParameterCase
    value: CamelCase
  - key:   readability-identifier-naming.TypeTemplateParameterCase
    value: CamelCase
  - key:   readability-identifier-naming.ValueTemplateParameterCase
    value: CamelCase
  - key:   readability-identifier-naming.TemplateTemplateParameterCase
    value: CamelCase

  # Modernization: enforce trailing return types and other C++23 idioms.
  - key:   modernize-use-trailing-return-type.TransformLambdas
    value: 'all'
  - key:   modernize-use-trailing-return-type.TransformFunctions
    value: 'all'

  # Performance defaults.
  - key:   performance-unnecessary-value-param.AllowedTypes
    value: 'std::string_view;std::span'
  - key:   performance-for-range-copy.AllowedTypes
    value: 'std::string_view;std::span'

  # Const-correctness: nexenne treats every non-reassigned local as const.
  - key:   misc-const-correctness.AnalyzeValues
    value: 'true'
  - key:   misc-const-correctness.AnalyzeReferences
    value: 'true'
  - key:   misc-const-correctness.WarnPointersAsValues
    value: 'true'
  - key:   misc-const-correctness.TransformValues
    value: 'true'
  - key:   misc-const-correctness.TransformReferences
    value: 'true'

  # Readability thresholds, raised above the library's real maxima (a matrix
  # inverse runs 120 lines, a codec reaches cognitive complexity 76) so genuine,
  # justified complexity does not warn while runaway growth still does.
  - key:   readability-function-cognitive-complexity.Threshold
    value: 100
  - key:   readability-function-size.LineThreshold
    value: 150
  - key:   readability-implicit-bool-conversion.AllowIntegerConditions
    value: false
  - key:   readability-implicit-bool-conversion.AllowPointerConditions
    value: false
  - key:   readability-braces-around-statements.ShortStatementLines
    value: 0
