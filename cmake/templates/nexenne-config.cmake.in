@PACKAGE_INIT@

#
# Umbrella package for nexenne. Supports both:
#   find_package(nexenne)                          # pulls every shipped module
#   find_package(nexenne COMPONENTS math physics)  # pulls a subset
#
# After find_package, link to one of:
#   nexenne::all       all shipped modules at once
#   nexenne::math      one specific module
#   nexenne::physics
#

include(CMakeFindDependencyMacro)

set(_nexenne_known_components "@_nexenne_components@")

set(_nexenne_requested ${nexenne_FIND_COMPONENTS})
if(NOT _nexenne_requested)
    set(_nexenne_requested ${_nexenne_known_components})
endif()

foreach(_comp IN LISTS _nexenne_requested)
    if(NOT _comp IN_LIST _nexenne_known_components)
        set(nexenne_FOUND FALSE)
        set(nexenne_NOT_FOUND_MESSAGE "Unknown nexenne component: ${_comp}")
        return()
    endif()
    find_dependency(nexenne-${_comp} REQUIRED)
    set(nexenne_${_comp}_FOUND TRUE)
endforeach()

# nexenne-targets.cmake defines the nexenne::all aggregate, whose interface
# references every module target, so including it only resolves when all of them
# are loaded. Pull it in for a full find_package(nexenne); a COMPONENTS subset
# gets just the requested per-module targets (nexenne::<comp>).
set(_nexenne_all_loaded TRUE)
foreach(_comp IN LISTS _nexenne_known_components)
    if(NOT _comp IN_LIST _nexenne_requested)
        set(_nexenne_all_loaded FALSE)
    endif()
endforeach()
if(_nexenne_all_loaded)
    include("${CMAKE_CURRENT_LIST_DIR}/nexenne-targets.cmake")
endif()

check_required_components(nexenne)
